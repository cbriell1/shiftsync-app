// filepath: prisma/schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

model Location {
  id               Int             @id @default(autoincrement())
  name             String          @unique 
  address          String?
  email            String?
  phoneNumber      String?
  isActive         Boolean         @default(true)
  sendReportEmails Boolean         @default(true) 
  
  users            User[]     
  shifts           Shift[]    
  timeCards        TimeCard[] 
  templates        ShiftTemplate[] 
  checklists       Checklist[]     
  events           Event[]
}

model Event {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  type        String    @default("TOURNAMENT") // TOURNAMENT, BLACKOUT, HOLIDAY, etc.
  locationId  Int?      // Null means all locations
  location    Location? @relation(fields: [locationId], references: [id])
  impact      String    @default("NORMAL")     // NORMAL, SKIP_GENERATION
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([startDate, endDate])
  @@index([locationId])
}

model User {
  id                  Int        @id @default(autoincrement())
  name                String     
  pinCode             String?    
  role                Role       @default(EMPLOYEE)
  systemRoles         String[]   @default(["Front Desk"]) 
  isActive            Boolean    @default(true)
  receiveReportEmails Boolean    @default(true) 
  receiveChatEmails   Boolean    @default(true) 
  lastLoginAt         DateTime?  
  
  locationIds    Int[]      @default([])

  locationId     Int?
  location       Location?  @relation(fields:[ locationId ], references:[ id ])
  
  courtReserveId String?
  phoneNumber    String?
  
  email          String?    @unique
  emailVerified  DateTime?
  image          String?

  shifts         Shift[]
  timeCards      TimeCard[]
  checklists     Checklist[]     
  templates      ShiftTemplate[]
  feedbacks      Feedback[]
  
  messages       Message[]
  announcements  Announcement[]
  auditLogs      AuditLog[]      
  errorLogs      ErrorLog[]
  feedbackComments FeedbackComment[]

  accounts       Account[]
  sessions       Session[]
  Authenticator  Authenticator[]

  @@index([isActive])
}
 
model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? 
  access_token      String? 
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? 
  session_state     String?
 
  user User @relation(fields:[userId], references:[id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@index([userId]) 
}
 
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields:[userId], references:[id], onDelete: Cascade)
  
  @@index([userId]) 
  @@index([expires])
}
 
model Authenticator {
  credentialID         String  @unique
  userId               Int
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([userId, credentialID])
}

model PayPeriod {
  id           Int          @id @default(autoincrement())
  year         Int        
  periodNumber Int        
  startDate    DateTime   
  endDate      DateTime   
  timeCards    TimeCard[]

  @@unique([ year, periodNumber ])
}

model Shift {
  id          Int        @id @default(autoincrement())
  startTime   DateTime
  endTime     DateTime
  status      String     @default("OPEN") 
  locationId  Int
  location    Location   @relation(fields:[ locationId ], references:[ id ])
  userId      Int?
  assignedTo  User?      @relation(fields: [ userId ], references:[ id ])

  @@index([startTime, endTime])
  @@index([locationId])
  @@index([userId])
}

model TimeCard {
  id          Int          @id @default(autoincrement())
  clockIn     DateTime
  clockOut    DateTime?
  totalHours  Float?
  status      String       @default("PENDING")
  userId      Int
  user        User         @relation(fields:[ userId ], references: [ id ])
  locationId  Int
  location    Location     @relation(fields:[ locationId ], references:[ id ])
  payPeriodId Int?
  payPeriod   PayPeriod?   @relation(fields:[ payPeriodId ], references:[ id ])
  
  checklists  Checklist[] 

  @@index([clockIn])
  @@index([userId])
  @@index([locationId])
}

model Member {
  id               Int         @id @default(autoincrement())
  lastName         String
  firstName        String
  location         String?
  notes            String?     
  bonusNotes       String?     
  family           String?     // Used as the grouping key for family allotments
  membershipLevel  String      @default("STANDARD") // STANDARD, PLATINUM
  renewalDate      String?     // MM-DD-YY
  lastResetDate    DateTime?   // Tracks the last time passes were reset for the period
  totalPasses      Int         @default(12)
  lastBeverageDate DateTime?   
  usages           PassUsage[]
  snackUsages      SnackUsage[]
  giftCards        GiftCard[]  

  @@index([lastName])
  @@index([family])
}

model PassUsage {
  id          Int      @id @default(autoincrement())
  dateUsed    String
  amount      Int      // Negative for "reverts" or "grants"
  initials    String?
  description String?  // Optional note for grants or corrections
  memberId    Int
  member      Member   @relation(fields: [ memberId ], references:[ id ], onDelete: Cascade)

  @@index([memberId])
}

model SnackUsage {
  id        Int      @id @default(autoincrement())
  memberId  Int
  member    Member   @relation(fields: [memberId], references: [id])
  dateUsed  DateTime @default(now())

  @@index([memberId])
  @@index([dateUsed])
}

model GiftCard {
  id               Int      @id @default(autoincrement())
  code             String   @unique
  initialAmount    Float
  remainingBalance Float
  recipientName    String?  
  memberId         Int?     
  member           Member?  @relation(fields:[memberId], references:[id])
  issuedAt         DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([memberId])
}

model ShiftTemplate {
  id             Int      @id @default(autoincrement())
  locationId     Int
  location       Location @relation(fields:[locationId], references:[id])
  dayOfWeek      Int      
  startTime      String   
  endTime        String   
  startDate      String?  
  endDate        String?  
  checklistTasks String[] @default([]) 
  userId         Int?     
  user           User?    @relation(fields:[userId], references:[id])

  @@index([locationId])
  @@index([dayOfWeek])
}

model Checklist {
  id                 Int       @id @default(autoincrement())
  date               DateTime  @default(now())
  userId             Int
  user               User      @relation(fields: [userId], references:[id])
  locationId         Int
  location           Location  @relation(fields:[locationId], references:[id])
  timeCardId         Int?      
  timeCard           TimeCard? @relation(fields:[timeCardId], references:[id]) 
  notes              String?
  previousShiftNotes String?   
  completedTasks     String[]  @default([])
  missedTasks        String[]  @default([])
  photoUrls          String[]  @default([])

  @@index([timeCardId])
  @@index([userId])
  @@index([date])
}

model GlobalTask {
  id   Int    @id @default(autoincrement())
  name String @unique
}

model Feedback {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references:[id], onDelete: Cascade)
  type        String   
  description String
  status      String   @default("OPEN") 
  devNotes    String?
  comments    FeedbackComment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([userId])
  @@index([status])
}

model FeedbackComment {
  id          Int      @id @default(autoincrement())
  content     String
  feedbackId  Int
  feedback    Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([feedbackId])
}

model Message {
  id                Int      @id @default(autoincrement())
  content           String
  senderId          Int
  sender            User     @relation(fields:[senderId], references: [id], onDelete: Cascade)
  isGlobal          Boolean  @default(true)
  targetUserIds     Int[]    @default([])
  targetLocationIds Int[]    @default([])
  createdAt         DateTime @default(now())

  @@index([createdAt])
  @@index([senderId])
}

model Announcement {
  id                Int      @id @default(autoincrement())
  title             String
  content           String
  authorId          Int
  author            User     @relation(fields:[authorId], references:[id], onDelete: Cascade)
  isGlobal          Boolean  @default(true)
  targetLocationIds Int[]    @default([])
  createdAt         DateTime @default(now())

  @@index([createdAt])
  @@index([authorId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // e.g., "TRANSACTION", "LOGIN", "DELETE"
  details   String   // Text description
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model ErrorLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  message   String
  stack     String?
  path      String?
  severity  String   @default("ERROR") // ERROR, FATAL, WARNING
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([severity])
}
